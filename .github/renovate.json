{
  "extends": [
    "config:recommended",
    ":disableRateLimiting",
    ":semanticCommits",
    ":rebaseStalePrs",
    ":separateMultipleMajorReleases",
    ":separatePatchReleases",
    "github>serubin/flux-infra//.github/renovate/commit.json",
    "github>serubin/flux-infra//.github/renovate/labels.json"
  ],
  "dependencyDashboardTitle": "Renovate Dashboard",
  "suppressNotifications": [
    "prIgnoreNotification"
  ],
  "flux": {
    "managerFilePatterns": [
      "infrastructure/**/*.yaml",
      "apps/**/*.yaml",
      "charts/**/*.yaml",
      "clusters/**/*.yaml"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/^apps/(base|prod|staging)/.*\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "apps/**/*.yaml"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "infrastructure/**/*.yaml",
        "apps/**/*.yaml",
        "charts/**/*.yaml",
        "clusters/**/*.yaml"
      ],
      "matchStrings": [
        "datasource=(?<datasource>\\S+) depName=(?<depName>.*?)\n *version: (?<currentValue>.*)\n"
      ],
      "datasourceTemplate": "{{#if datasource}}{{{datasource}}}{{else}}helm{{/if}}"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "velero/velero-plugin-for-aws"
      ],
      "allowedVersions": "<=1.14.0",
      "description": "Pinned: v1.14.1's aws-sdk-go-v2 sends an x-amz-tagging header that Backblaze B2 rejects (HTTP 400), breaking all Velero backups. Raise this cap once upstream releases the conditional-Tagging fix (commit 8dbd6b8)."
    },
    {
      "matchPackageNames": [
        "ghcr.io/serubin/serubin-net",
        "ghcr.io/serubin/dysautonomia-lounge-website",
        "ghcr.io/j-paterson/personalwebsite",
        "ghcr.io/anaximand/lemonhope"
      ],
      "automerge": true,
      "matchUpdateTypes": [
        "patch",
        "minor",
        "major"
      ],
      "automergeStrategy": "squash",
      "platformAutomerge": true
    }
  ]
}
